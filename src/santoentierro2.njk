---
layout: layouts/base.njk
title: Santo Entierro
bodyClass: page-light
---

<article class="history-page">
  <header class="page-header wrap">
    <span class="pre-title">Viernes Santo</span>
    <h1>Santo Entierro</h1>
    <div class="header-line"></div>
  </header>

  {# --- SECCIÓN 1: HITOS DEL RECORRIDO (Estilo Timeline) --- #}
  <section class="history-timeline">
    <div class="wrap">
      
      <div class="timeline-item">
        <div class="year">20:00 h</div>
        <div class="timeline-content">
          <h3>Salida</h3>
          <p>El Santo Entierro comienza en la <strong>Basílica de Santa María</strong>, tras la Procesión General de Cofradías y Hermandades. Los Caballeros y Damas se reúnen para iniciar el Santo Entierro, custodiando la Sagrada Urna.</p>
        </div>
      </div>

      <div class="timeline-item has-image"> 
        <div class="year">20:30 h</div>
        <div class="timeline-content">
          <div class="timeline-text">
            <h3>Paso por Carrera Oficial</h3>
            <p>El cortejo atraviesa el corazón de Elche. El silencio se apodera de las calles al paso de <strong>Cristo Yacente</strong>, precedido por el aroma del incienso de los acólitos.</p>
          </div>
          <div class="timeline-image">
            <img src="/img/image_baa381.jpg" alt="Santo Sepulcro saliendo de la Basílica Santa María">
          </div>
        </div>
      </div>

      <div class="timeline-item">
        <div class="year">22:30 h</div>
        <div class="timeline-content">
          <h3>Entrada en la Plaça Baix</h3>
          <p>Con el alumbrado público de la plaza mayor totalmente apagado, hace su entrada la imagen de <strong>Cristo Yacente</strong> en el Santo Sepulcro. Al llegar al centro de la plaza mayor el cortejo es acompañada de un coro de cámara. A continuación el sacerdote consiliario de la hermandad.</p>
        </div>
      </div>

      <div class="timeline-item has-image"> 
        <div class="year">23:00 h</div>
        <div class="timeline-content">
          <h3>Trencà del Guió</h3>
          <p>Uno de los momentos más emotivos de la Semana Santa ilicitana en la <strong>Plaça de Baix</strong>. Ante el trono de <strong>Nuestra Señora de los Dolores en su Soledad</strong>, y el <strong>Santo Sepulcro</strong> se procede a la rotura del guión negro, simbolizando que la muerte no tiene la última palabra.</p>
          <div class="timeline-image">
            <img src="/img/trencaor-2024_104.jpg" alt="Trencà del Guió anyo 2024">
          </div>
        </div>
      </div>

    </div>
  </section>

  {# --- SECCIÓN 2: MAPA INTERACTIVO (Satelital + Bocadillo) --- #}
  <section class="map-section wrap" style="margin-top: 50px; margin-bottom: 80px;">
    <div class="intro-grid">
      <div class="history-text">
        <h2>Mapa del Itinerario</h2>
        <p>El recorrido sigue el trazado de la antigua muralla medieval. La línea marca el paso de la Procesión General del Viernes Santo.</p>
                
      </div>

      <div class="map-container-wrapper">
        <div id="map-itinerario" style="height: 550px; width: 100%; border-radius: 12px; border: 1px solid #ccc; box-shadow: 0 10px 30px rgba(0,0,0,0.15);"></div>
      </div>
    </div>
  </section>

</article>

{# --- LEAFLET ASSETS --- #}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 1. Inicializar el mapa con tus coordenadas
    var map = L.map('map-itinerario').setView([38.2665, -0.6975], 16);

    // 2. Capa Satelital Híbrida (Google Maps)
    L.tileLayer('https://{s}.google.com/vt/lyrs=s,h&x={x}&y={y}&z={z}', {
        maxZoom: 20,
        subdomains:['mt0','mt1','mt2','mt3'],
        attribution: '© Google Maps'
    }).addTo(map);

    // 3. Icono tipo Bocadillo Blanco con CSS
    var customHtmlIcon = L.divIcon({
      html: `
        <div class="marker-pin-wrapper">
          <div class="marker-pin">
            <img src="/img/escudo.png" alt="Cruz">
          </div>
        </div>
      `,
      className: 'custom-div-icon',
      iconSize: [40, 52],
      iconAnchor: [20, 52],
      popupAnchor: [0, -45]
    });

    // 4. Tus coordenadas actualizadas
    var puntosProcesion = [
      [38.267133, -0.697898], // Salida Santa María
      [38.267309, -0.697981], // Inicio plaza Congreso Eucarístico
      [38.267331, -0.696541], // Final calle Uberna
      [38.267228, -0.696279], // Plaça de la Mercè
      [38.267194, -0.695216], // Puente Ortices
      [38.266456, -0.695347], // Casa Palacio Jorge Juan
      [38.266269, -0.695890], // Carrer Pere Ibarra
      [38.266153, -0.696292], // Carrer Ample
      [38.265908, -0.696838], // Carrer Bisbe Tormo
      [38.265242, -0.698799], // Plaça Baix
      [38.265133, -0.699353], // Puente de Canalejas
      [38.265608, -0.699385],
      [38.265817, -0.699281],
      [38.265863, -0.699204],
      [38.265898, -0.698990],
      [38.265937, -0.698720], // Esquina con Major de la Vila
      [38.266942, -0.698688], // Esquina con carrer la Fira
      [38.266978, -0.698049],
      [38.267118, -0.697891],
      [38.267133, -0.697898]  // Regreso
    ];

    // 5. Dibujar el camino (Blanco para resaltar en satélite)
    var path = L.polyline(puntosProcesion, {
      color:  '#000000',
      weight: 5,
      opacity: 0.9,
    }).addTo(map);

    // 6. Marcadores
    L.marker([38.265242, -0.698799], {icon: customHtmlIcon}).addTo(map)
      .bindPopup('<b>Plaça de Baix</b><br>Trencà del Guió (23:00h aprox.)');

    L.marker([38.267133, -0.697898]).addTo(map)
      .bindPopup('<b>Basílica de Santa María</b><br>Salida y Regreso');

    map.fitBounds(path.getBounds());
  });
</script>

<style>
  /* Contenedor principal del marcador */
  .marker-pin-wrapper {
    position: relative;
    width: 32px;
    height: 42px; /* Más alto para dar sensación de chincheta estilizada */
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* El cuerpo circular superior */
  .marker-circle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #000000;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 5px rgba(0,0,0,0.3);
    z-index: 2;
  }

  /* La punta aguda inferior */
  .marker-tip {
    width: 0;
    height: 0;
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-top: 14px solid #000000; /* Crea el ángulo agudo hacia abajo */
    margin-top: -5px; /* Une la punta con el círculo */
    z-index: 1;
  }

  /* Imagen de la Hermandad */
  .marker-circle img {
    width: 20px;
    height: 20px;
    object-fit: contain;
    /* Si el logo es oscuro y quieres que resalte en blanco, usa la línea de abajo: */
    /* filter: brightness(0) invert(1); */
  }
</style>
