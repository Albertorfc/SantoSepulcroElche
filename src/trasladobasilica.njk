    // 6. Marcadores
    L.marker([38.265242, -0.698799], {icon: customHtmlIcon}).addTo(map)
      .bindPopup('<b>Plaça de Baix</b><br>Trencà del Guió (23:00h aprox.)');

    L.marker([38.267133, -0.697898], {icon: customHtmlIcon}).addTo(map)
      .bindPopup('<b>Basílica de Santa María</b><br>Salida y Regreso');

    map.fitBounds(path.getBounds());
  });
</script>

<style>
  .custom-div-icon {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .marker-pin {
    width: 36px;
