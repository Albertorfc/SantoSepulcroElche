      [38.265006, -0.699352], // Alfonso XII
      [38.265133, -0.699353], // Puente de Canalejas
      [38.265608, -0.699385],
      [38.265817, -0.699281],
      [38.265863, -0.699204],
      [38.265898, -0.698990],
