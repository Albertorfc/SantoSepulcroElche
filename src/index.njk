<style>
  /* --- ESTILOS DE LA NUEVA GALERÍA --- */
  .home-gallery {
    padding: 100px 0;
    background: #050505;
    text-align: center;
  }

  .triptico-container {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr; /* La imagen central es ligeramente más ancha */
    gap: 20px;
    margin-top: 50px;
    align-items: center;
  }

  .triptico-item {
    position: relative;
    overflow: hidden;
    height: 500px;
    border: 1px solid rgba(255,255,255,0.1);
    transition: transform 0.5s ease;
  }

  .triptico-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(20%) contrast(110%); /* Toque sutil para unificar colores */
    transition: all 0.6s ease;
  }

  .triptico-item:hover img {
    transform: scale(1.05);
    filter: sepia(0%) contrast(100%);
  }

  .img-caption {
    position: absolute;
    bottom: 20px;
    left: 0;
    right: 0;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gold);
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
    padding: 20px 0;
    opacity: 0.8;
  }

  /* Responsive para móvil */
  @media (max-width: 768px) {
    .triptico-container {
      grid-template-columns: 1fr;
    }
    .triptico-item {
      height: 350px;
    }
  }

  /* ... (tus estilos anteriores del Hero y Countdown) ... */
</style>
