---
layout: layouts/base.njk
title: Inicio
bodyClass: home
---

<section class="hero-section">
  <div class="hero-content wrap">
    <div class="hero-text">
      <span class="hero-subtitle">Hermandad · 1852 · Elche</span>
      <h1>Caballeros del Santo Sepulcro</h1>
      <p>Acompañando a Cristo Yacente en su Santo Sepulcro.</p>
      <div class="hero-buttons">
        <a href="/historia/" class="btn-primary">Nuestra Historia</a>
        <a href="/cultos/" class="btn-secondary">Agenda de Cultos</a>
      </div>
    </div>
  </div>
</section>

<section class="countdown-wrapper">
  <div class="wrap">
    <div class="section-title">
      <h2>Próxima Estación de Penitencia</h2>
      <p>Viernes Santo · <span id="target-date-display">Cargando fecha...</span></p>
    </div>

    <div class="countdown-container">
      <div class="countdown-item">
        <span id="months" class="number">00</span>
        <span class="label">Meses</span>
      </div>
      <div class="countdown-item">
        <span id="days" class="number">00</span>
        <span class="label">Días</span>
      </div>
      <div class="countdown-item">
        <span id="hours" class="number">00</span>
        <span class="label">Horas</span>
      </div>
      <div class="countdown-item">
        <span id="minutes" class="number">00</span>
        <span class="label">Minutos</span>
      </div>
      <div class="countdown-item">
        <span id="seconds" class="number">00</span>
        <span class="label">Segundos</span>
      </div>
    </div>
  </div>
</section>

<section class="social-section">
  <div class="wrap">
    <div class="section-title">
      <h2>Sigue nuestra actualidad</h2>
      <p>@hermandadsantosepulcroelche en Instagram</p>
    </div>
    
    <div class="instagram-container">
      <div class="sk-instagram-feed" data-embed-id="25665614"></div>
      <script src="https://widgets.sociablekit.com/instagram-feed/widget.js" defer></script>
    </div>
  </div>
</section>

<style>
  /* Estilos específicos para el Hero de la Home */
  .hero-section {
    height: 100vh;
    display: flex;
    align-items: center;
    background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/img/hero-bg.jpg') center/cover no-repeat;
    text-align: left;
  }

  .hero-subtitle {
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 4px;
    font-size: 14px;
    display: block;
    margin-bottom: 15px;
  }

  .hero-text h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(40px, 8vw, 80px);
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .hero-text p {
    max-width: 500px;
    font-size: 18px;
    opacity: 0.8;
    margin-bottom: 35px;
  }

  .btn-primary {
    background: var(--gold);
    color: #000;
    padding: 15px 35px;
    text-decoration: none;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 1px;
    margin-right: 15px;
    transition: background 0.3s;
  }

  .btn-secondary {
    border: 1px solid #fff;
    color: #fff;
    padding: 15px 35px;
    text-decoration: none;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s;
  }

  .btn-secondary:hover {
    background: #fff;
    color: #000;
  }

  .countdown-wrapper {
    padding: 100px 0;
    background: #000;
    text-align: center;
  }

  .section-title h2 {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    margin-bottom: 10px;
  }

  .section-title p {
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 13px;
    margin-bottom: 40px;
  }
</style>
