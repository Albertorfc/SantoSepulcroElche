---
layout: layouts/base.njk
title: Área de Miembros
bodyClass: page-light
---
{# Usamos inline styles para no tocar el CSS y asegurar que se vea en blanco #}
<section style="padding: 160px 20px 100px; text-align: center; background-color: #ffffff;">
  <div class="wrap">
    
    <div id="logged-out-content" style="max-width: 400px; margin: 0 auto;">
      <span style="color: var(--gold); text-transform: uppercase; letter-spacing: 2px; font-size: 12px; font-weight: bold;">Privacidad</span>
      <h1 style="color: #000; font-family: 'Playfair Display', serif; margin: 10px 0 30px; font-size: 32px;">Acceso Hermandad</h1>
      
      <form id="login-form" style="text-align: left;">
        <div style="margin-bottom: 20px;">
          <label style="display: block; color: #666; font-size: 11px; text-transform: uppercase; margin-bottom: 5px;">Correo Electrónico</label>
          <input type="email" id="email" name="email" required 
                 style="width: 100%; padding: 12px; border: 1px solid #ddd; background: #fff; color: #000;">
        </div>
        
        <div style="margin-bottom: 30px;">
          <label style="display: block; color: #666; font-size: 11px; text-transform: uppercase; margin-bottom: 5px;">Contraseña</label>
          <input type="password" id="password" name="password" required 
                 style="width: 100%; padding: 12px; border: 1px solid #ddd; background: #fff; color: #000;">
        </div>
        
        {# Usamos tu clase btn-primary que ya existe en components.css #}
        <button type="submit" class="btn-primary" style="width: 100%; cursor: pointer; border: none;">
          Entrar
        </button>
      </form>
    </div>

    <div id="logged-in-content" style="display: none;">
      <h2 style="color: #000; font-family: 'Playfair Display', serif;">Bienvenido, Hermano</h2>
      <p style="color: #666; margin-bottom: 20px;">Ya puedes acceder a los documentos internos.</p>
      <button class="btn-primary" onclick="netlifyIdentity.logout()" style="background: #000; border-color: #000;">Cerrar Sesión</button>
    </div>

  </div>
</section>

<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  // El script se queda igual que lo tenías, es perfecto.
  const form = document.getElementById('login-form');
  if(form) {
    form.addEventListener('submit', e => {
      e.preventDefault();
      netlifyIdentity.gotrue.login(form.email.value, form.password.value)
        .then(() => window.location.reload())
        .catch(() => alert("Credenciales incorrectas."));
    });
  }
  netlifyIdentity.on('init', user => {
    if (user) {
      document.getElementById('logged-out-content').style.display = 'none';
      document.getElementById('logged-in-content').style.display = 'block';
    }
  });
</script>
