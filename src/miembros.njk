---
layout: layouts/base.njk
title: Área de Miembros
bodyClass: page-light
---
<section class="section-hero">
  <div class="wrap">
    <span class="pre-title">Privacidad y Seguridad</span>
    <h1 class="section-title">Acceso Hermandad</h1>
    <div class="hero-line"></div>
  </div>
</section>

<section class="login-section">
  <div class="wrap wrap--narrow"> <div id="logged-out-content">
      <p class="login-intro">Introduzca sus credenciales para acceder al contenido exclusivo de hermanos.</p>
      
      <form id="login-form" class="modern-form">
        <div class="form-group">
          <input type="email" id="email" name="email" required placeholder=" ">
          <label for="email">Correo Electrónico</label>
          <div class="line"></div>
        </div>
        
        <div class="form-group">
          <input type="password" id="password" name="password" required placeholder=" ">
          <label for="password">Contraseña</label>
          <div class="line"></div>
        </div>
        
        <div class="form-actions">
          <button type="submit" class="btn-primary">Entrar</button>
        </div>
      </form>
    </div>

    <div id="logged-in-content" style="display: none;" class="portal-content">
      <h2 class="section-title">Bienvenido, Hermano</h2>
      <p>Ya puedes acceder a los documentos internos.</p>
      <br>
      <button class="btn-secondary" onclick="netlifyIdentity.logout()">Cerrar Sesión</button>
    </div>
  </div>
</section>

<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  const form = document.getElementById('login-form');
  if(form) {
    form.addEventListener('submit', e => {
      e.preventDefault();
      const email = form.email.value;
      const password = form.password.value;
      netlifyIdentity.gotrue.login(email, password)
        .then(() => window.location.reload())
        .catch(() => alert("Credenciales incorrectas."));
    });
  }

  netlifyIdentity.on('init', user => {
    if (user) {
      document.getElementById('logged-out-content').style.display = 'none';
      document.getElementById('logged-in-content').style.display = 'block';
    }
  });
</script>
