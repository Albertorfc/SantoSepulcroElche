<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <title>{{ title }} | Hermandad de Caballeros del Santo Sepulcro de Elche</title>
  <meta name="description" content="Sitio oficial de la Hermandad del Santo Sepulcro de Elche. Fundada en 1852.">
  
  <link rel="icon" href="/img/sepulcro-n.png" type="image/png">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
  
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="{{ bodyClass }}">

  <div id="preloader">
    <div class="preloader-logo">
      <img src="/img/escudo.png" alt="Escudo Hermandad" id="loading-logo">
    </div>
  </div>

  {% include "partials/header.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/js/menu.js"></script>
  <script src="/js/countdown.js"></script>

  <script>
  window.addEventListener('load', () => {
  const preloader = document.getElementById('preloader');
  if (!preloader) return;

  // Condición: Solo ejecutamos la animación si estamos en la Home
  const isHome = document.body.classList.contains('home');

  if (isHome) {
    // 1. Espera mínima (100ms) para que el navegador procese la carga
    setTimeout(() => {
      // 2. Inicia el viaje hacia la esquina de inmediato
      preloader.classList.add('shrink-logo');
      
      // 3. El fondo desaparece mientras el logo viaja
      setTimeout(() => {
        preloader.classList.add('fade-out');
        
        // 4. Limpieza final
        setTimeout(() => {
          preloader.style.display = 'none';
        }, 500);
      }, 400); 
    }, 100); 
  } else {
    // Si NO es la home, quitamos el preloader de golpe sin animación
    preloader.style.display = 'none';
  }
});
  </script>

</body>
</html>
