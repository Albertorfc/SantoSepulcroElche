<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <title>{{ title }} | Hermandad de Caballeros del Santo Sepulcro de Elche</title>
  <meta name="description" content="Sitio de la Hermandad del Santo Sepulcro de Elche. Fundada en 1852.">
  
  <link rel="icon" href="/img/sepulcro-n.png" type="image/png">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Ibarra+Real+Nova:ital,wght@0,400..700;1,400..700&family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/history.css">
  <link rel="stylesheet" href="/css/styles.css"> 
</head>

<body class="{{ bodyClass }}">

  <div id="preloader">
    <div class="preloader-logo">
      <img src="/img/escudo.png" alt="Escudo Hermandad" id="loading-logo">
    </div>
  </div>

  {% include "partials/header.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/js/menu.js"></script>
  <script src="/js/countdown.js"></script>

  <script>
   // Este script debe ir al final, antes del </body>
(function() {
  const preloader = document.getElementById('preloader');
  if (!preloader) return;

  // Verificamos si es la Home
  const isHome = document.body.classList.contains('home');

  if (isHome) {
    // Lo hacemos visible inmediatamente
    preloader.classList.add('active');

    // 1. Pausa mínima casi imperceptible (100ms)
    setTimeout(() => {
      // 2. Inicia el viaje a la esquina
      preloader.classList.add('shrink-logo');
      
      // 3. Empezamos a desvanecer el fondo muy rápido
      setTimeout(() => {
        preloader.classList.add('fade-out');
        
        setTimeout(() => {
          preloader.style.display = 'none';
        }, 400);
      }, 300); // El fondo empieza a irse antes de que termine el viaje
      
    }, 500); 
  } else {
    // En cualquier otra página, nos aseguramos de que no exista
    preloader.remove(); 
  }
})();
  </script>

</body>
</html>
